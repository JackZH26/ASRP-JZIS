#!/usr/bin/env bash
# ASRP — Agent Science Research Platform CLI
# Usage: asrp <command> [options]

set -e

ASRP_ROOT="${ASRP_ROOT:-$(pwd)}"
ASRP_VERSION="0.1.0"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

show_help() {
    echo "ASRP — Agent Science Research Platform v${ASRP_VERSION}"
    echo ""
    echo "Usage: asrp <command> [options]"
    echo ""
    echo "Commands:"
    echo "  init              Initialize a new ASRP workspace"
    echo "  register          Pre-register a new experiment"
    echo "  status            Show workspace status"
    echo "  validate          Run cross-validation on an experiment"
    echo "  audit             View or add audit log entries"
    echo "  report            Generate research report"
    echo "  doctor            Run health checks"
    echo "  help              Show this help message"
    echo ""
    echo "Environment:"
    echo "  ASRP_ROOT         Workspace root directory (default: current directory)"
}

cmd_init() {
    echo -e "${BLUE}ASRP Workspace Initialization${NC}"
    echo "=============================="
    echo ""

    local workspace="${1:-.}"
    mkdir -p "$workspace"
    cd "$workspace"

    # Create directory structure
    echo -e "${GREEN}Creating directory structure...${NC}"
    mkdir -p workspace/{data,registry,papers,audit,messages,literature,logs}
    mkdir -p backups
    mkdir -p agents/{theorist,engineer,reviewer,librarian,itdoctor}

    # Create config from template if not exists
    if [ ! -f config.yaml ]; then
        echo -e "${GREEN}Creating config.yaml...${NC}"
        cat > config.yaml << 'CFG'
# ASRP Configuration — Edit this file with your settings
# See config.example.yaml for documentation

api_keys:
  anthropic: "${ANTHROPIC_API_KEY}"
  google: "${GOOGLE_API_KEY}"

agents:
  theorist:
    model: "anthropic/claude-opus-4-6"
    thinking: "high"
  engineer:
    model: "anthropic/claude-sonnet-4-5"
    thinking: "off"
  reviewer:
    model: "anthropic/claude-opus-4-6"
    thinking: "high"
    read_only: true
  librarian:
    model: "google/gemini-2.5-flash"
  itdoctor:
    model: "google/gemini-2.5-flash"

deployment:
  mode: "single"
  workspace: "./workspace"

research:
  require_preregistration: true
  require_cross_validation: true
CFG
    fi

    # Create .env if not exists
    if [ ! -f .env ]; then
        echo -e "${GREEN}Creating .env template...${NC}"
        cat > .env << 'ENV'
# API Keys — Fill in your values
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ENV
    fi

    # Create .gitignore
    cat > .gitignore << 'GI'
config.yaml
.env
*.key
*.pem
*.secret
__pycache__/
*.pyc
.DS_Store
node_modules/
backups/
workspace/logs/
GI

    # Initialize audit log
    if [ ! -f workspace/audit/audit.jsonl ]; then
        echo "{\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"agent\":\"system\",\"type\":\"init\",\"action\":\"workspace_created\",\"details\":\"ASRP workspace initialized\"}" > workspace/audit/audit.jsonl
    fi

    echo ""
    echo -e "${GREEN}✅ ASRP workspace initialized at: $(pwd)${NC}"
    echo ""
    echo "Next steps:"
    echo "  1. Edit .env and add your API keys"
    echo "  2. Edit config.yaml to customize agent settings"
    echo "  3. Run: asrp register   — to pre-register your first experiment"
    echo "  4. Run: asrp status     — to check workspace status"
}

cmd_register() {
    local registry_dir="$ASRP_ROOT/workspace/registry"
    mkdir -p "$registry_dir"

    local date_str=$(date -u +%Y-%m-%d)
    local count=$(ls "$registry_dir"/EXP-${date_str}-*.json 2>/dev/null | wc -l)
    local next=$((count + 1))
    local exp_id="EXP-${date_str}-$(printf '%03d' $next)"
    local filepath="$registry_dir/${exp_id}.json"

    echo -e "${BLUE}Register New Experiment: ${exp_id}${NC}"
    echo "======================================="
    echo ""

    read -p "Hypothesis (falsifiable statement): " hypothesis
    read -p "Method (brief description): " method
    read -p "Expected result: " expected
    read -p "Success criteria (quantitative): " success
    read -p "Failure criteria (what disproves it): " failure
    read -p "Estimated compute time (hours): " compute_hours
    read -p "Researcher name/agent: " researcher

    cat > "$filepath" << REGEOF
{
  "experiment_id": "${exp_id}",
  "date_registered": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "researcher": "${researcher}",
  "hypothesis": "${hypothesis}",
  "method": "${method}",
  "parameters": {},
  "expected_result": "${expected}",
  "success_criteria": "${success}",
  "failure_criteria": "${failure}",
  "estimated_compute_hours": ${compute_hours:-0},
  "status": "registered",
  "actual_result": "",
  "outcome": "",
  "errors_found": [],
  "lessons_learned": ""
}
REGEOF

    # Log to audit trail
    echo "{\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"agent\":\"${researcher}\",\"type\":\"experiment\",\"action\":\"registered\",\"details\":\"${exp_id}: ${hypothesis}\"}" >> "$ASRP_ROOT/workspace/audit/audit.jsonl"

    echo ""
    echo -e "${GREEN}✅ Experiment registered: ${filepath}${NC}"
    echo ""
    echo "Next: Run your experiment, then update the file with actual results."
    echo "  - Set status to 'completed' or 'failed'"
    echo "  - Fill in actual_result, outcome, errors_found, lessons_learned"
    echo "  - Run: asrp validate ${exp_id}"
}

cmd_status() {
    echo -e "${BLUE}ASRP Workspace Status${NC}"
    echo "====================="
    echo ""

    # Check workspace exists
    if [ ! -d "$ASRP_ROOT/workspace" ]; then
        echo -e "${RED}No ASRP workspace found. Run: asrp init${NC}"
        exit 1
    fi

    # Count experiments
    local total=$(ls "$ASRP_ROOT/workspace/registry"/*.json 2>/dev/null | wc -l)
    local registered=$(grep -l '"registered"' "$ASRP_ROOT/workspace/registry"/*.json 2>/dev/null | wc -l)
    local completed=$(grep -l '"completed"' "$ASRP_ROOT/workspace/registry"/*.json 2>/dev/null | wc -l)
    local refuted=$(grep -l '"refuted"' "$ASRP_ROOT/workspace/registry"/*.json 2>/dev/null | wc -l)

    echo "Experiments:"
    echo "  Total registered: $total"
    echo "  Pending:          $registered"
    echo "  Completed:        $completed"
    echo "  Refuted:          $refuted"
    echo ""

    # Count papers
    local papers=$(find "$ASRP_ROOT/workspace/papers" -name "*.tex" -o -name "*.pdf" 2>/dev/null | wc -l)
    echo "Papers: $papers files"
    echo ""

    # Audit log size
    local audit_lines=0
    if [ -f "$ASRP_ROOT/workspace/audit/audit.jsonl" ]; then
        audit_lines=$(wc -l < "$ASRP_ROOT/workspace/audit/audit.jsonl")
    fi
    echo "Audit log: $audit_lines entries"
    echo ""

    # Disk usage
    local disk=$(du -sh "$ASRP_ROOT/workspace" 2>/dev/null | cut -f1)
    echo "Workspace size: $disk"
    echo ""

    # Pending messages
    local msgs=$(ls "$ASRP_ROOT/workspace/messages"/*.json 2>/dev/null | wc -l)
    if [ "$msgs" -gt 0 ]; then
        echo -e "${YELLOW}⚠ Pending messages: $msgs${NC}"
    fi

    # Config check
    if [ -f "$ASRP_ROOT/.env" ]; then
        local keys_set=$(grep -v "^#" "$ASRP_ROOT/.env" | grep -v "^$" | grep "=." | wc -l)
        echo "API keys configured: $keys_set"
    else
        echo -e "${RED}⚠ No .env file found. Run: asrp init${NC}"
    fi
}

cmd_validate() {
    local exp_id="$1"
    if [ -z "$exp_id" ]; then
        echo "Usage: asrp validate <experiment_id>"
        echo ""
        echo "Available experiments:"
        ls "$ASRP_ROOT/workspace/registry"/*.json 2>/dev/null | xargs -I {} basename {} .json
        exit 1
    fi

    local filepath="$ASRP_ROOT/workspace/registry/${exp_id}.json"
    if [ ! -f "$filepath" ]; then
        echo -e "${RED}Experiment not found: ${exp_id}${NC}"
        exit 1
    fi

    echo -e "${BLUE}Cross-Validation Check: ${exp_id}${NC}"
    echo "=================================="
    echo ""

    # Display experiment details
    python3 -c "
import json, sys
with open('$filepath') as f:
    exp = json.load(f)
print(f\"Hypothesis: {exp['hypothesis']}\")
print(f\"Status: {exp['status']}\")
print(f\"Expected: {exp['expected_result']}\")
print(f\"Actual: {exp.get('actual_result', 'NOT YET RECORDED')}\")
print(f\"Outcome: {exp.get('outcome', 'NOT YET RECORDED')}\")
if exp.get('errors_found'):
    print(f\"Errors found: {len(exp['errors_found'])}\")
    for e in exp['errors_found']:
        print(f\"  - {e}\")
" 2>/dev/null || cat "$filepath"

    echo ""
    echo "Validation checklist:"
    echo "  [ ] Results independently reproduced?"
    echo "  [ ] Parameters match pre-registration?"
    echo "  [ ] Convergence tests performed?"
    echo "  [ ] Literature checked for prior art?"
    echo "  [ ] Error bars / uncertainties quantified?"
    echo ""
    echo "To record validation: create workspace/data/${exp_id}/validation/report.json"
}

cmd_audit() {
    local audit_file="$ASRP_ROOT/workspace/audit/audit.jsonl"
    if [ ! -f "$audit_file" ]; then
        echo -e "${RED}No audit log found. Run: asrp init${NC}"
        exit 1
    fi

    local action="${1:-view}"
    if [ "$action" = "view" ]; then
        echo -e "${BLUE}Audit Trail (last 20 entries)${NC}"
        echo "=============================="
        tail -20 "$audit_file" | python3 -c "
import json, sys
for line in sys.stdin:
    try:
        e = json.loads(line.strip())
        ts = e.get('timestamp','?')[:16]
        agent = e.get('agent','?')
        action = e.get('action','?')
        details = e.get('details','')[:80]
        severity = e.get('severity','')
        sev_mark = ' ⚠️' if severity == 'critical' else ''
        print(f'  {ts}  [{agent:10s}] {action:12s} {details}{sev_mark}')
    except:
        pass
" 2>/dev/null || tail -20 "$audit_file"
    elif [ "$action" = "add" ]; then
        read -p "Agent: " agent
        read -p "Type (hypothesis/methodology/result/decision): " type
        read -p "Action: " act
        read -p "Details: " details
        echo "{\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"agent\":\"${agent}\",\"type\":\"${type}\",\"action\":\"${act}\",\"details\":\"${details}\"}" >> "$audit_file"
        echo -e "${GREEN}✅ Audit entry added${NC}"
    fi
}

cmd_doctor() {
    echo -e "${BLUE}ASRP Health Check${NC}"
    echo "=================="
    echo ""

    local issues=0

    # Check workspace
    if [ -d "$ASRP_ROOT/workspace" ]; then
        echo -e "${GREEN}✓${NC} Workspace directory exists"
    else
        echo -e "${RED}✗${NC} Workspace directory missing"
        issues=$((issues + 1))
    fi

    # Check config
    if [ -f "$ASRP_ROOT/config.yaml" ]; then
        echo -e "${GREEN}✓${NC} config.yaml exists"
    else
        echo -e "${YELLOW}!${NC} config.yaml missing (using defaults)"
    fi

    # Check .env
    if [ -f "$ASRP_ROOT/.env" ]; then
        local empty_keys=$(grep "=$" "$ASRP_ROOT/.env" | grep -v "^#" | wc -l)
        if [ "$empty_keys" -gt 0 ]; then
            echo -e "${YELLOW}!${NC} .env has $empty_keys unconfigured keys"
        else
            echo -e "${GREEN}✓${NC} .env configured"
        fi
    else
        echo -e "${RED}✗${NC} .env missing"
        issues=$((issues + 1))
    fi

    # Check audit log integrity
    if [ -f "$ASRP_ROOT/workspace/audit/audit.jsonl" ]; then
        local valid=$(python3 -c "
import json
count = 0
errors = 0
with open('$ASRP_ROOT/workspace/audit/audit.jsonl') as f:
    for line in f:
        count += 1
        try: json.loads(line.strip())
        except: errors += 1
print(f'{count} entries, {errors} malformed')
" 2>/dev/null || echo "unable to parse")
        echo -e "${GREEN}✓${NC} Audit log: $valid"
    else
        echo -e "${RED}✗${NC} Audit log missing"
        issues=$((issues + 1))
    fi

    # Check disk space
    local disk_pct=$(df "$ASRP_ROOT" 2>/dev/null | tail -1 | awk '{print $5}' | tr -d '%')
    if [ -n "$disk_pct" ]; then
        if [ "$disk_pct" -gt 90 ]; then
            echo -e "${RED}✗${NC} Disk usage: ${disk_pct}% (CRITICAL)"
            issues=$((issues + 1))
        elif [ "$disk_pct" -gt 80 ]; then
            echo -e "${YELLOW}!${NC} Disk usage: ${disk_pct}% (WARNING)"
        else
            echo -e "${GREEN}✓${NC} Disk usage: ${disk_pct}%"
        fi
    fi

    # Check for stale messages
    local stale=$(find "$ASRP_ROOT/workspace/messages" -name "*.json" -mmin +60 2>/dev/null | wc -l)
    if [ "$stale" -gt 0 ]; then
        echo -e "${YELLOW}!${NC} $stale messages older than 1 hour"
    fi

    echo ""
    if [ "$issues" -gt 0 ]; then
        echo -e "${RED}Found $issues issue(s). Please fix before proceeding.${NC}"
    else
        echo -e "${GREEN}All checks passed ✓${NC}"
    fi
}

cmd_report() {
    echo -e "${BLUE}Research Report Generator${NC}"
    echo "========================="
    echo ""
    echo "Scanning workspace..."
    echo ""

    # Count everything
    local exps=$(ls "$ASRP_ROOT/workspace/registry"/*.json 2>/dev/null | wc -l)
    local papers=$(find "$ASRP_ROOT/workspace/papers" \( -name "*.tex" -o -name "*.pdf" \) 2>/dev/null | wc -l)
    local data_files=$(find "$ASRP_ROOT/workspace/data" -type f 2>/dev/null | wc -l)
    local audit_entries=0
    [ -f "$ASRP_ROOT/workspace/audit/audit.jsonl" ] && audit_entries=$(wc -l < "$ASRP_ROOT/workspace/audit/audit.jsonl")

    echo "=== Research Summary ==="
    echo "Experiments registered: $exps"
    echo "Paper files: $papers"
    echo "Data files: $data_files"
    echo "Audit entries: $audit_entries"
    echo ""

    # List experiments with outcomes
    if [ "$exps" -gt 0 ]; then
        echo "=== Experiment Outcomes ==="
        python3 -c "
import json, glob, os
files = sorted(glob.glob('$ASRP_ROOT/workspace/registry/*.json'))
for f in files:
    with open(f) as fh:
        exp = json.load(fh)
    status = exp.get('status', '?')
    outcome = exp.get('outcome', '-')
    hyp = exp.get('hypothesis', '?')[:60]
    print(f\"  {exp['experiment_id']:20s}  {status:15s}  {outcome:12s}  {hyp}\")
" 2>/dev/null
    fi

    echo ""
    echo "Full report generation (PDF) coming in a future version."
}

# Main dispatch
case "${1:-help}" in
    init)     shift; cmd_init "$@" ;;
    register) shift; cmd_register "$@" ;;
    status)   shift; cmd_status "$@" ;;
    validate) shift; cmd_validate "$@" ;;
    audit)    shift; cmd_audit "$@" ;;
    report)   shift; cmd_report "$@" ;;
    doctor)   shift; cmd_doctor "$@" ;;
    help|--help|-h) show_help ;;
    *) echo "Unknown command: $1"; show_help; exit 1 ;;
esac
