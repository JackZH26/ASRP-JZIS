#!/usr/bin/env bash
# ASRP Auto-Setup — Run by Assistant Agent on first launch
# Creates project structure and installs agent skills

set -e
ASRP_ROOT="${1:-.}"
cd "$ASRP_ROOT"

echo "[ASRP Auto-Setup] Starting..."

# Create workspace directories
for dir in workspace/data workspace/registry workspace/papers workspace/audit workspace/messages workspace/literature workspace/logs; do
    mkdir -p "$dir"
done
for role in theorist engineer reviewer librarian itdoctor assistant; do
    mkdir -p "agents/$role"
done
mkdir -p backups

# Initialize audit log
if [ ! -f workspace/audit/audit.jsonl ]; then
    echo "{\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"agent\":\"assistant\",\"type\":\"init\",\"action\":\"auto_setup\",\"details\":\"ASRP workspace auto-initialized by Assistant Agent\"}" > workspace/audit/audit.jsonl
fi

# Copy SOUL files for each agent
for role in theorist engineer reviewer librarian itdoctor assistant; do
    if [ -f "agents/${role}-soul.md" ] && [ ! -f "agents/${role}/SOUL.md" ]; then
        cp "agents/${role}-soul.md" "agents/${role}/SOUL.md"
        echo "[ASRP] Installed SOUL for $role"
    fi
    if [ -f "agents/${role}-init.md" ] && [ ! -f "agents/${role}/INIT.md" ]; then
        cp "agents/${role}-init.md" "agents/${role}/INIT.md"
        echo "[ASRP] Installed INIT for $role"
    fi
done

# Install skills for all agents
if [ -x "agents/skills/install.sh" ]; then
    echo "[ASRP] Installing agent skills..."
    bash agents/skills/install.sh all 2>/dev/null || echo "[ASRP] Some skills need manual install"
fi

# Create .gitignore if missing
if [ ! -f .gitignore ]; then
    cat > .gitignore << 'GI'
config.yaml
.env
*.key
*.pem
*.secret
__pycache__/
*.pyc
.DS_Store
node_modules/
backups/
workspace/logs/
GI
fi

# Create default config.yaml if missing
if [ ! -f config.yaml ]; then
    cat > config.yaml << 'CFG'
# ASRP Configuration — Auto-generated by Assistant
deployment:
  mode: "single"
  workspace: "./workspace"

agents:
  theorist:
    model: "auto"
    thinking: "high"
  engineer:
    model: "auto"
    thinking: "off"
  reviewer:
    model: "auto"
    thinking: "high"
    read_only: true
  librarian:
    model: "auto"
  itdoctor:
    model: "auto"
    heartbeat_interval: 300
  assistant:
    model: "openrouter/anthropic/claude-sonnet-4-5"

fallback:
  provider: "openrouter"
  enabled: true

research:
  require_preregistration: true
  require_cross_validation: true
CFG
fi

echo "[ASRP Auto-Setup] Complete!"
echo "[ASRP] 6 agents configured, workspace ready"
echo "[ASRP] Run 'openclaw start' to begin"
